# Environment variables for Job-AI-Auto-Apply-UI (MVP)

# LLM provider selection: openrouter | google
LLM_PROVIDER=openrouter

# Default model identifier for the chosen provider
# Examples:
# - openrouter: openrouter/auto or provider/model (see provider docs)
# - google: gemini-1.5-pro or gemini-1.5-flash
LLM_MODEL=

# API keys (do NOT commit real values)
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# Determinism and timeouts
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=30

# Optional networking
# HTTP(S) proxy for agent runs, e.g., http://user:pass@host:port
# HTTP_PROXY=
# HTTPS_PROXY=

