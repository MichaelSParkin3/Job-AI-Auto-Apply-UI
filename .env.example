# Environment variables for Job-AI-Auto-Apply-UI (MVP)

# LLM provider selection: openrouter | google
LLM_PROVIDER=openrouter

# Default model identifier for the chosen provider
# Examples:
# - openrouter: openrouter/auto or provider/model (see provider docs)
# - google: gemini-1.5-pro or gemini-1.5-flash
LLM_MODEL=

# API keys (do NOT commit real values)
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# Determinism and timeouts
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=30

# Optional networking
# HTTP(S) proxy for agent runs, e.g., http://user:pass@host:port
# HTTP_PROXY=
# HTTPS_PROXY=

# Resume upload detection (Lever) — Feature Flags
# Enable LLM-powered element finding for resume input; default off (0)
AUTO_APPLY_USE_LLM_LOCATOR=0

# Emit a structured snapshot when resume upload is not detected
# Includes files_len, resumeStorageId length, banner styles, filename text, and truncated widget HTML
AUTO_APPLY_DEBUG_RESUME_WIDGET=0

# Max seconds to wait for upload success signals (default 25)
AUTO_APPLY_RESUME_WAIT_TIMEOUT_SECONDS=25
