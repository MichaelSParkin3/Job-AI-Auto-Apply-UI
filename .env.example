# Job-AI-Auto-Apply-UI — .env example
#
# Copy this file to .env and fill values as needed.
# Use 0/1 for booleans. Leave unset to use defaults.

## LLM & Provider
# openrouter | google (see README for details)
LLM_PROVIDER=openrouter
# Default model for provider (e.g., openrouter/auto, deepseek/deepseek-v3, gemini-1.5-pro)
LLM_MODEL=

# API keys (do NOT commit real values)
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
# Optional: If you use OpenAI-compatible clients directly
# OPENAI_API_KEY=

# Determinism and timeouts
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=30
# Optional provider branding
# LLM_REFERER=
# LLM_USER_AGENT=

## Networking
# Single proxy var also honored (takes precedence over HTTP(S)_PROXY)
# PROXY_URL=http://user:pass@host:port
# HTTP(S) proxies if you prefer these
# HTTP_PROXY=
# HTTPS_PROXY=
# Override User-Agent if needed
# USER_AGENT=
# Allow-list of domains (comma-separated)
# Default: google.*,jobs.lever.co
# ALLOWED_DOMAINS=google.com,www.google.com,jobs.lever.co

## Diagnostics & Artifacts
# Turn on all capture quickly
AUTO_APPLY_DIAGNOSTICS=0
# Capture video or HAR independently
AUTO_APPLY_CAPTURE_VIDEO=0
AUTO_APPLY_CAPTURE_HAR=0
# Where to store artifacts (namespaced by profile at runtime)
AUTO_APPLY_ARTIFACTS_DIR=data/artifacts

## Resume Upload (Lever) — Feature Flags
# Enable LLM-powered element finding for resume input
AUTO_APPLY_USE_LLM_LOCATOR=0
# Emit structured snapshot when upload not detected
AUTO_APPLY_DEBUG_RESUME_WIDGET=0
# Max seconds to wait for upload success signals
AUTO_APPLY_RESUME_WAIT_TIMEOUT_SECONDS=25
# Re-enable verbose JS eval polling logs (off by default)
# AUTO_APPLY_DEBUG_JS_EVAL=1

## Stealth / Anti-Detection
# Applied to process env before browser launch
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=America/Los_Angeles
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=800
# Prefer clean browser without default extensions (1=disable)
AUTO_APPLY_DISABLE_DEFAULT_EXTENSIONS=1
# Chrome/Chromium launch args (semicolon-separated)
# Defaults: --disable-autofill; --disable-autofill-keyboard-accessory-view; --disable-features=Autofill,AutofillServerCommunication
# This disables Chrome's built-in autocomplete/autofill to prevent interference with form dropdowns
# Note: Use semicolon (;) as delimiter since Chrome args may contain commas in their values
# AUTO_APPLY_CHROME_ARGS=--disable-autofill;--disable-autofill-keyboard-accessory-view;--disable-features=Autofill,AutofillServerCommunication

## General Behavior
DWELL_SECONDS=0.8
JITTER_SECONDS=0.4
MAX_TABS=3
RETRIES=2
DISCOVERY_WINDOW_HOURS=24
DISCOVERY_CAP=10
# Override profiles directory (defaults to ./profiles)
# AUTO_APPLY_PROFILES_DIR=

## Captcha Detection — Vision Fallback (Optional)
# Enable vision-based captcha detection as fallback when DOM detection fails
# Recommended: Enable this if you encounter frequent false negatives (captchas not detected)
# Default: 0 (disabled)
# Cost: $0 if using free tier models
# Performance: Adds 3-5 seconds only when DOM detection finds nothing
# AUTO_APPLY_CAPTCHA_VISUAL_CHECK=1

# Vision model to use for captcha detection (OpenRouter format)
# Free options (recommended):
#   - google/gemini-2.0-flash-exp:free (DEFAULT - fastest, 1M context, best accuracy)
#   - meta-llama/llama-3.2-90b-vision-instruct:free (90B params, excellent reasoning)
#   - qwen/qwen2.5-vl-32b-instruct:free (32B params, good for object recognition)
# Paid ultra-cheap options (< $0.001 per check):
#   - google/gemini-2.0-flash-001 (~$0.0006 per check)
# Default: google/gemini-2.0-flash-exp:free
# AUTO_APPLY_CAPTCHA_VISION_MODEL=google/gemini-2.0-flash-exp:free

# Seconds to wait before taking vision screenshot (allows slow captchas to load)
# Recommended: 3.0 for most sites, increase to 5.0 for slow-loading sites
# Default: 3.0
# CAPTCHA_VISUAL_DELAY_SECONDS=3.0

## Captcha Detection — Interactive Handling (Supervised Mode)
# Seconds to wait for user to manually solve captcha before auto-blocking
# Only applies in supervised mode (--supervised flag)
# In auto mode, captchas are blocked immediately without waiting
# Default: 30
# Options: [S] Mark as submitted, [B] Mark as blocked, or wait for timeout
# AUTO_APPLY_CAPTCHA_TIMEOUT_SECONDS=30

