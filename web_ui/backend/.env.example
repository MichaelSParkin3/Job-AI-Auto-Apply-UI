# Backend Configuration

# Server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5000
BACKEND_DEBUG=False

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# File Paths
PROFILES_DIR=profiles
QUEUES_DIR=data/queues
ARTIFACTS_DIR=data/artifacts
SETTINGS_FILE=.env

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# LLM Configuration
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-opus-4
OPENROUTER_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here

# CLI Configuration
DISCOVERY_WINDOW_HOURS=24
DISCOVERY_CAP=10
DWELL_SECONDS=0.8
JITTER_SECONDS=0.4
MAX_TABS=3
RETRIES=2

# Diagnostics
AUTO_APPLY_DIAGNOSTICS=0
AUTO_APPLY_USE_LLM_LOCATOR=0
AUTO_APPLY_DEBUG_RESUME_WIDGET=0

# Performance
QUEUE_POLL_INTERVAL_SECONDS=2
API_RESPONSE_TIMEOUT_SECONDS=30
